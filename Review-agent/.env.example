# ============================================================
# Review Reply Agent — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- App ---
SECRET_KEY=your-super-secret-jwt-key-change-this
DATABASE_URL=sqlite:///./review_agent.db
FRONTEND_URL=http://localhost:5173

# --- Claude AI ---
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- Google Business Profile API ---
# Set to "true" for demo/testing WITHOUT needing Google API approval
# Set to "false" when you have real Google API credentials
GOOGLE_MOCK_MODE=true

# Required when GOOGLE_MOCK_MODE=false:
# 1. Create a project at: https://console.cloud.google.com/
# 2. Enable "Google Business Profile API"
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add redirect URI: http://localhost:8000/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
